# Custom headers for static site hosting (Cloudflare Pages / Netlify)
# Note: GitHub Pages does not natively support _headers files.
# If hosting on GitHub Pages, consider using a CDN/proxy that supports
# header rewrites, or migrate to Cloudflare Pages/Netlify.
# The .nojekyll file is still useful to prevent Jekyll processing.

# Sitemap and robots
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  X-Content-Type-Options: nosniff

/robots.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

# HTML files - root and subdirectories
/*.html
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/apidocs/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/architecture/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/home/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/jacoco/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/jacoco-aggregate/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/jacoco-it/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/jacoco-ut/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/testapidocs/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/xref/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

/xref-test/*
  Content-Type: text/html; charset=utf-8
  X-Content-Type-Options: nosniff

# JSON files
/*.json
  Content-Type: application/json; charset=utf-8
  X-Content-Type-Options: nosniff

# CSS files
/css/*
  Content-Type: text/css; charset=utf-8
  X-Content-Type-Options: nosniff

# JavaScript files
/js/*
  Content-Type: application/javascript; charset=utf-8
  X-Content-Type-Options: nosniff

# Images - root level
/*.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/*.svg
  Content-Type: image/svg+xml
  X-Content-Type-Options: nosniff

/*.jpg
  Content-Type: image/jpeg
  X-Content-Type-Options: nosniff

/*.gif
  Content-Type: image/gif
  X-Content-Type-Options: nosniff

/*.ico
  Content-Type: image/x-icon
  X-Content-Type-Options: nosniff

# Images - /images/ directory
/images/*
  X-Content-Type-Options: nosniff

/images/*.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/images/*.svg
  Content-Type: image/svg+xml
  X-Content-Type-Options: nosniff

/images/*.jpg
  Content-Type: image/jpeg
  X-Content-Type-Options: nosniff

/images/*.gif
  Content-Type: image/gif
  X-Content-Type-Options: nosniff

# Images - /img/ directory
/img/*.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/img/*.svg
  Content-Type: image/svg+xml
  X-Content-Type-Options: nosniff

/img/*.jpg
  Content-Type: image/jpeg
  X-Content-Type-Options: nosniff

/img/*.gif
  Content-Type: image/gif
  X-Content-Type-Options: nosniff

# Screenshots
/screenshots/*
  X-Content-Type-Options: nosniff

/screenshots/*.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

# Fonts - root level
/*.woff
  Content-Type: font/woff
  X-Content-Type-Options: nosniff

/*.woff2
  Content-Type: font/woff2
  X-Content-Type-Options: nosniff

/*.ttf
  Content-Type: font/ttf
  X-Content-Type-Options: nosniff

/*.eot
  Content-Type: application/vnd.ms-fontobject
  X-Content-Type-Options: nosniff

# Fonts - /fonts/ directory
/fonts/*.woff
  Content-Type: font/woff
  X-Content-Type-Options: nosniff

/fonts/*.woff2
  Content-Type: font/woff2
  X-Content-Type-Options: nosniff

/fonts/*.ttf
  Content-Type: font/ttf
  X-Content-Type-Options: nosniff

/fonts/*.eot
  Content-Type: application/vnd.ms-fontobject
  X-Content-Type-Options: nosniff

/fonts/*.svg
  Content-Type: image/svg+xml
  X-Content-Type-Options: nosniff
