<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>com.hack23.cia</groupId>
    <artifactId>parent-web-pom</artifactId>
    <version>2026.5.17</version>
    <relativePath>../parent-web-pom/pom.xml</relativePath>
  </parent>
  <artifactId>cia-dist-deb</artifactId>
  <packaging>pom</packaging>
  <name>cia-dist-deb</name>
  <url>scm:git:ssh://git@github.com/Hack23/cia.git/cia-dist-deb</url>
  <scm>
    <connection>scm:git:ssh://git@github.com/Hack23/cia.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/Hack23/cia.git</developerConnection>
    <tag>HEAD</tag>
    <url>https://github.com/Hack23/cia/tree/master/</url>
  </scm>
  <distributionManagement>
    <site>
      <id>github</id>
      <url>scm:git:ssh://git@github.com/Hack23/cia.git/cia-dist-deb</url>
    </site>
  </distributionManagement>
  <dependencies>
    <dependency>
      <groupId>org.eclipse.jetty</groupId>
      <artifactId>jetty-home</artifactId>
      <version>${cia.project.versions.jetty}</version>
      <type>zip</type>
      <exclusions>
        <exclusion>
          <groupId>*</groupId>
          <artifactId>*</artifactId>
        </exclusion>
      </exclusions>
    </dependency>
    <dependency>
      <groupId>com.hack23.cia</groupId>
      <artifactId>citizen-intelligence-agency</artifactId>
      <version>${project.version}</version>
      <type>war</type>
    </dependency>
  </dependencies>
  <build>
    <plugins>
      <plugin>
        <groupId>org.cyclonedx</groupId>
        <artifactId>cyclonedx-maven-plugin</artifactId>
        <version>2.9.1</version>
        <executions>
          <execution>
            <goals>
              <goal>makeAggregateBom</goal>
            </goals>
            <phase>verify</phase>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.spdx</groupId>
        <artifactId>spdx-maven-plugin</artifactId>
        <version>1.0.3</version>
        <configuration></configuration>
        <executions>
          <execution>
            <id>build-spdx</id>
            <goals>
              <goal>createSPDX</goal>
            </goals>
            <phase>verify</phase>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>keytool-maven-plugin</artifactId>
        <version>2.0.2</version>
        <configuration>
          <keystore>${project.build.directory}/keystore.p12</keystore>
          <storepass>changeit</storepass>
          <storetype>PKCS12</storetype>
          <keypass>changeit</keypass>
          <skipIfExist>true</skipIfExist>
        </configuration>
        <executions>
          <execution>
            <?m2e ignore?>
            <id>generateKeyPair</id>
            <goals>
              <goal>generateKeyPair</goal>
            </goals>
            <phase>generate-resources</phase>
            <configuration>
              <alias>ciadistdebkeys</alias>
              <dname>cn=www.hack23.com, ou=None, L=None, ST=None, o=None, c=SE</dname>
              <sigalg>SHA256withRSA</sigalg>
              <ext></ext>
              <validity>365</validity>
              <keyalg>RSA</keyalg>
              <keysize>4096</keysize>
            </configuration>
          </execution>
          <execution>
            <id>removekeystore</id>
            <goals>
              <goal>clean</goal>
            </goals>
            <phase>clean</phase>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <executions>
          <execution>
            <id>prepare-deb-staging</id>
            <goals>
              <goal>run</goal>
            </goals>
            <phase>prepare-package</phase>
            <configuration>
              <target>
                <!-- Ensure a clean deb-staging directory before preparing files -->
                <delete dir="${project.build.directory}/deb-staging" failonerror="false"></delete>
                <!-- Unpack jetty-home zip to staging area (use the bundled bin/jetty.sh
                     shipped with Jetty 12.1; the legacy bin-fix override is no longer needed). -->
                <unzip dest="${project.build.directory}/deb-staging/opt/cia" src="${settings.localRepository}/org/eclipse/jetty/jetty-home/${cia.project.versions.jetty}/jetty-home-${cia.project.versions.jetty}.zip"></unzip>
                <!-- Move jetty-home contents up one level to strip version directory -->
                <move includeEmptyDirs="true" todir="${project.build.directory}/deb-staging/opt/cia">
                  <fileset dir="${project.build.directory}/deb-staging/opt/cia/jetty-home-${cia.project.versions.jetty}"></fileset>
                </move>
                <delete dir="${project.build.directory}/deb-staging/opt/cia/jetty-home-${cia.project.versions.jetty}"></delete>
                <!-- Preserve executable bit on shell scripts shipped by jetty-home;
                     Ant <unzip> strips Unix permission bits so restore 0755 explicitly. -->
                <chmod perm="755">
                  <fileset dir="${project.build.directory}/deb-staging/opt/cia/bin" includes="**/*.sh"></fileset>
                </chmod>
                <!-- Unpack WAR to staging area -->
                <unzip dest="${project.build.directory}/deb-staging/opt/cia/cia-base/webapps/cia" src="${basedir}/../citizen-intelligence-agency/target/citizen-intelligence-agency-${project.version}.war"></unzip>
                <!-- Copy config files to staging area -->
                <copy file="${basedir}/src/main/config/jetty/cia-base/webapps/cia.xml" overwrite="true" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/webapps/cia.xml"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/resources/jetty-logging.properties" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/resources/jetty-logging.properties"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/deploy.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/deploy.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/gzip.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/gzip.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/http2c.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/http2c.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/http2.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/http2.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/http.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/http.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/https.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/https.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/jmx.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/jmx.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/jsp.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/jsp.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/jstl.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/jstl.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/resources.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/resources.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/requestlog.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/requestlog.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/accept-rate-limit.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/accept-rate-limit.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/server.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/server.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/ssl.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/ssl.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/threadpool.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/threadpool.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/console-capture.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/console-capture.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/logging-logback.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/logging-logback.ini"></copy>
                <copy file="${basedir}/src/main/config/jetty/cia-base/start.d/websocket.ini" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/start.d/websocket.ini"></copy>
                <copy file="${basedir}/src/main/config/etc/default/cia" tofile="${project.build.directory}/deb-staging/etc/default/cia"></copy>
                <copy file="${project.build.directory}/keystore.p12" tofile="${project.build.directory}/deb-staging/opt/cia/cia-base/etc/keystore.p12"></copy>
              </target>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.vafer</groupId>
        <artifactId>jdeb</artifactId>
        <version>1.14</version>
        <executions>
          <execution>
            <goals>
              <goal>jdeb</goal>
            </goals>
            <phase>package</phase>
            <configuration>
              <deb>${project.build.directory}/${project.artifactId}-${project.version}.all.deb</deb>
              <controlDir>${basedir}/src/deb/control</controlDir>
              <skipPOMs>false</skipPOMs>
              <dataSet>
                <data>
                  <type>directory</type>
                  <src>${project.build.directory}/deb-staging</src>
                  <excludes>**/keystore.p12,opt/cia/bin/**</excludes>
                  <mapper>
                    <type>perm</type>
                    <prefix>/</prefix>
                    <user>root</user>
                    <group>root</group>
                    <filemode>644</filemode>
                    <dirmode>755</dirmode>
                  </mapper>
                </data>
                <data>
                  <type>directory</type>
                  <src>${project.build.directory}/deb-staging</src>
                  <includes>opt/cia/bin/**</includes>
                  <mapper>
                    <type>perm</type>
                    <prefix>/</prefix>
                    <user>root</user>
                    <group>root</group>
                    <filemode>755</filemode>
                    <dirmode>755</dirmode>
                  </mapper>
                </data>
                <data>
                  <type>directory</type>
                  <src>${project.build.directory}/deb-staging</src>
                  <includes>**/keystore.p12</includes>
                  <mapper>
                    <type>perm</type>
                    <prefix>/</prefix>
                    <user>root</user>
                    <group>root</group>
                    <filemode>600</filemode>
                    <dirmode>755</dirmode>
                  </mapper>
                </data>
              </dataSet>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <executions>
          <execution>
            <id>enforce-versions</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <configuration>
              <rules>
                <requireMavenVersion>
                  <version>${cia.project.versions.maven}</version>
                </requireMavenVersion>
                <requireJavaVersion>
                  <version>${jdk.src.version}</version>
                </requireJavaVersion>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
